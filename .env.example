# ── Database 
POSTGRES_USER=abplatform
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=abplatform

# Для локальной разработки (без Docker):
# DATABASE_URL=postgresql+asyncpg://abplatform:changeme_in_production@localhost:5432/abplatform
# Для Docker Compose (задаётся автоматически через environment):
# DATABASE_URL=postgresql+asyncpg://abplatform:changeme_in_production@postgres:5432/abplatform

# ── Redis ────
# Для локальной разработки:
# REDIS_URL=redis://localhost:6379
# Для Docker Compose (задаётся автоматически):
# REDIS_URL=redis://redis:6379

# ── App ──────
SECRET_KEY=changeme_use_openssl_rand_hex_32
ENVIRONMENT=production

# ── AI (выбери один вариант) ──────────────────────────────────
#AI_PROVIDER=disabled
AI_PROVIDER=ollama
# AI_PROVIDER=openai

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:latest
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
